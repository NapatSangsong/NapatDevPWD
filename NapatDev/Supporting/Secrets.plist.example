<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
    Copy this file to `Secrets.plist` in the same folder (it's gitignored)
    and paste your Anthropic API key below. Grab one at:

        https://console.anthropic.com/settings/keys

    The real `Secrets.plist` is bundled into the app at build time. It never
    touches git. If you don't create it, the in-app Assistant tab shows a
    warning and is disabled — everything else keeps working.
    -->
    <key>anthropic_api_key</key>
    <string>sk-ant-api03-PASTE-YOUR-KEY-HERE</string>
</dict>
</plist>
