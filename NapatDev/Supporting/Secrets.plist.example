<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
    Copy this file to `Secrets.plist` in the same folder (it's gitignored)
    and paste your keys below. The real `Secrets.plist` is bundled into the
    app at build time; it never touches git.

    - anthropic_api_key: your Claude key (for the Assistant). Omit if you
      don't want the assistant. Get one at:
        https://console.anthropic.com/settings/keys

    - supabase_url / supabase_publishable_key: only needed if you want the
      vault to sync to napats.dev via Supabase. The publishable key is
      designed to be public — it's the client-side-safe version.
    -->
    <key>anthropic_api_key</key>
    <string>sk-ant-api03-PASTE-YOUR-KEY-HERE</string>

    <key>supabase_url</key>
    <string>https://YOUR-PROJECT.supabase.co</string>

    <key>supabase_publishable_key</key>
    <string>sb_publishable_PASTE-HERE</string>
</dict>
</plist>
